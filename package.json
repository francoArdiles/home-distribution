{
  "name": "home-distribution",
  "version": "0.1.0",
  "type": "module",
  "description": "Aplicación web para diseñar y planificar la distribución de elementos en un terreno para vivienda autosustentable",
  "main": "src/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "prepare": "husky install"
  },
  "keywords": [
    "terreno",
    "distribución",
    "autosustentable",
    "permacultura",
    "diseño",
    "planificación"
  ],
  "author": "ZeroClaw Assistant",
  "license": "MIT",
  "dependencies": {
    "jspdf": "^4.2.1",
    "konva": "^9.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.5",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.35.0",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^4.2.0",
    "vitest": "^0.29.0"
  },
  "lint-staged": {
    "*.{js,jsx}": ["npm run lint", "npm run test"]
