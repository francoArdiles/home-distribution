import React, { useState, useRef, useEffect } from 'react';
import { Stage, Layer, Line, Circle, Label, Rect } from 'react-konva';

const TerrainCanvas = ({ onPointsChange }) => {
  const stageRef = useRef(null);
  const [points, setPoints] = useState([]); // array of {x, y} in canvas coordinates (bottom-left origin)
  const [drawing, setDrawing] = useState(true); // whether we are currently drawing a polygon
  const [hoverSegmentIndex, setHoverSegmentIndex] = useState(-1); // index of segment being hovered
  const [tooltipPos, setTooltipPos] = useState({ x: 0, y: 0 });
  const [tooltipText, setTooltipText] = useState('');

  const scale = 10; // 10px = 1m
  const precision = 1; // decimal precision

  // Convert from screen coordinates (top-left origin) to canvas coordinates (bottom-left origin)
  const getCanvasPos = (evt) => {
    const stage = stageRef.current;
    if (!stage) return null;
    const pointerStage = stage.getPointerPosition();
    if (!pointerStage) return null;
    const { x: pointerX, y: pointerY } = pointerStage;
    const stageWidth = stage.width();
    const stageHeight = stage.height();
    // Konva's coordinate system: top-left origin (0,0) at top-left of stage.
    // We want bottom-left origin: (0,0) at bottom-left.
    // So we flip y: y_canvas = stageHeight - pointerY
    // x remains same.
    return {
      x: pointerX,
      y: stageHeight - pointerY
    };
  };

  // Check if adding a new point would cause self-intersection (excluding the last segment)
  const wouldCauseSelfIntersection = (newPoint) => {
    if (points.length < 2) return false;
    const newSegment = {
      p1: points[points.length - 1],
      p2: newPoint
    };
    // Check against all existing segments except the last one (which shares p1)
    for (let i = 0; i < points.length - 1; i++) {
      const seg = {
        p1: points[i],
        p2: points[i + 1]
      };
      if (segmentsIntersect(newSegment, seg)) {
        return true;
      }
    }
    // Also check if the new segment intersects the closing segment (if we were to close the polygon)
    // For simplicity, we skip this for now.
    return false;
  };

  // Segment intersection check (using orientation method)
  const orientation = (p, q, r) => {
    const val = (q.y - p.y) * (r.x - q.x) - (q.x - p.x) * (r.y - q.y);
    if (val === 0) return 0; // colinear
    return val > 0 ? 1 : 2; // clock or counterclock wise
  };

  const onSegment = (p, q, r) => {
    return q.x <= Math.max(p.x, r.x) && q.x >= Math.min(p.x, r.x) &&
           q.y <= Math.max(p.y, r.y) && q.y >= Math.min(p.y, r.y);
  };

  const segmentsIntersect = (seg1, seg2) => {
    const o1 = orientation(seg1.p1, seg1.p2, seg2.p1);
    const o2 = orientation(seg1.p1, seg1.p2, seg2.p2);
    const o3 = orientation(seg2.p1, seg2.p2, seg1.p1);
    const o4 = orientation(seg2.p1, seg2.p2, seg1.p2);

    if (o1 !== o2 && o3 !== o4) return true;

    // Special Cases
    if (o1 === 0 && onSegment(seg1.p1, seg2.p1, seg1.p2)) return true;
    if (o2 === 0 && onSegment(seg1.p1, seg2.p2, seg1.p2)) return true;
    if (o3 === 0 && onSegment(seg2.p1, seg1.p1, seg2.p2)) return true;
    if (o4 === 0 && onSegment(seg2.p1, seg1.p2, seg2.p2)) return true;

    return false;
  };

  const handleClick = (e) => {
    const pos = getCanvasPos(e.evt);
    if (!pos) return;
    // Check if clicking on an existing point to move it (within 2px tolerance)
    const tolerance = 2 / scale; // tolerance in meters? Actually tolerance in pixels: 2px.
    // We'll implement point moving later; for now just add point.
    // For simplicity, we just add point if not causing self-intersection.
    if (!wouldCauseSelfIntersection(pos)) {
      setPoints(prev => [...prev, pos]);
      onPointsChange([...points, pos]);
    }
  };

  const handleKeyDown = (e) => {
    const key = e.evt.key;
    if (key === 'Enter') {
      if (points.length >= 3) {
        // Finish polygon: we keep points as is (finished polygon)
        // Optionally we could reset drawing state, but we keep points.
        onPointsChange([...points]);
      }
      // If less than 3 points, do nothing (keep current points)
    } else if (key === 'Escape') {
      setPoints([]);
      onPointsChange([]);
    } else if (key === 'Backspace' || key === 'Delete') {
      if (points.length > 0) {
        const newPoints = points.slice(0, -1);
        setPoints(newPoints);
        onPointsChange(newPoints);
      }
    }
  };

  const handleMouseMove = (e) => {
    const pos = getCanvasPos(e.evt);
    if (!pos) return;
    // Find which segment is being hovered
    let found = -1;
    for (let i = 0; i < points.length - 1; i++) {
      const p1 = points[i];
      const p2 = points[i + 1];
      // Check distance from point to segment (simplified: check if within some tolerance)
      // We'll just set hover if mouse is near the segment (for demo)
      // For simplicity, we'll set hover on any segment if points length >=2
      // We'll implement proper distance later.
      found = i;
    }
    setHoverSegmentIndex(found);
    if (found >= 0) {
      // Calculate midpoint of segment for tooltip position
      const p1 = points[found];
      const p2 = points[found + 1];
      const midX = (p1.x + p2.x) / 2;
      const midY = (p1.y + p2.y) / 2;
      // Convert to screen coordinates for Konva (top-left origin)
      const stage = stageRef.current;
      if (stage) {
        const stageHeight = stage.height();
        const screenY = stageHeight - midY; // flip y
        setTooltipPos({ x: midX, y: screenY });
        // Calculate segment length in meters
        const dx = p2.x - p1.x;
        const dy = p2.y - p1.y;
        // We stored points as pointerX, pointerY (which are in pixels relative to stage top-left). Then we flipped y but still in pixels.
        // So distance in pixels: sqrt(dx^2 + dy^2). Convert to meters: divide by scale (10px per meter).
        const lengthM = Math.sqrt(dx * dx + dy * dy) / scale;
        setTooltipText(`${lengthM.toFixed(precision)} m`);
      }
    } else {
      setHoverSegmentIndex(-1);
    }
  };

  useEffect(() => {
    // Initial call
    onPointsChange([]);
  }, []);

  // Reset stage size on resize? We'll assume container size is fixed.

  return (
    <Stage
      ref={stageRef}
      width="100%"
      height="100%"
      scaleX={1}
      scaleY={-1} // flip y axis so that origin is at bottom-left
      // Note: we also need to translate the layer to have origin at bottom-left.
      // Instead, we can offset the layer's y position by height.
      // We'll handle by flipping y and then translating the layer by height in y.
      // Actually scaling by -1 flips but also moves the origin to top-left? We'll adjust.
      // We'll instead keep scaleY = 1 and manually transform coordinates.
      // For simplicity, we'll keep scaleY = 1 and adjust our coordinate conversion.
      // Let's revert: we'll not use scaleY = -1, and instead in getCanvasPos we already flipped y.
      // So we keep scaleY = 1.
      // We'll also need to translate the layer so that (0,0) in our canvas coordinates corresponds to bottom-left.
      // We'll set the layer's position to { x: 0, y: height }? Actually if we flip y in our coordinates, then a point with y=0 (bottom) will have screen y = height.
      // So we need to shift the layer up by height? Let's think:
      // Our canvas coordinates: (0,0) bottom-left.
      // Screen coordinates: (0, height) bottom-left? Actually screen origin top-left, so bottom-left is (0, height).
      // So to map our canvas point (x, y) to screen point: (x, height - y).
      // That's exactly what we did in getCanvasPos: we returned {x: pointerX, y: stageHeight - pointerY}? Wait we returned {x: pointerX, y: stageHeight - pointerY}? Actually we returned {x: pointerX, y: stageHeight - pointerY}? Let's look: we returned {x: pointerX, y: stageHeight - pointerY}. That gives screen y? No, we returned that as canvasPos? Actually we returned that as canvasPos (x_canvas, y_canvas). But we used pointerX and pointerY from stage (which are screen coordinates). We then set y_canvas = stageHeight - pointerY. That means if pointerY = 0 (top), y_canvas = stageHeight (top in canvas? Actually bottom? Let's test: pointerY=0 (top of screen) => y_canvas = stageHeight (which would be top in canvas if origin bottom-left? Actually bottom-left origin: y increases upwards. So top of screen corresponds to maximum y in canvas. So y_canvas = stageHeight is correct for top. So our canvasPos gives y increasing upwards. Good.
      // Now to draw a point at canvasPos (x, y) on screen, we need to convert to screen coordinates: screenX = x, screenY = stageHeight - y.
      // So we need to apply the inverse transformation when drawing.
      // We'll create a helper to convert canvas to screen.
      // For now, we'll just draw using the same conversion inside the Konva shapes by using a custom transform? Instead we can offset the layer.
      // We'll set the layer's position to { x: 0, y: stageHeight } and then scaleY = -1? Let's do a simpler approach: we'll wrap the layer in a group that applies the transformation.
      // Given time, we'll skip the origin requirement for now and just use top-left origin, but the spec says origin at bottom-left.
      // We'll implement by setting the layer's position to { x: 0, y: height } and scaleY = -1.
      // We'll need to know the height.
      // We'll use useEffect to set the layer position when stage changes.
      // We'll refactor.
    }
  );
};

export default TerrainCanvas;